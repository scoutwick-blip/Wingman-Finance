# Supabase Configuration (Optional)
# To enable cloud sync and authentication, create a Supabase project and add your credentials below.

# Your Supabase project URL
# Format: https://<project-ref>.supabase.co
# Found in: Project Dashboard > Connect (button at top) > Project URL
VITE_SUPABASE_URL=

# Your Supabase API key (publishable key or legacy anon key)
# New projects: sb_publishable_... (from Settings > API Keys > Publishable)
# Legacy projects: eyJhbG... (from Settings > API Keys > Legacy API Keys > anon)
# Both work as a drop-in replacement with createClient()
VITE_SUPABASE_ANON_KEY=

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
#
# STEP 1: Create Supabase Project
# ---------------------------------
# 1. Create a free account at https://supabase.com
# 2. Create a new project
# 3. Get your credentials:
#    Option A (new projects): Click the "Connect" button at the top of your dashboard
#      - Copy the Project URL → paste as VITE_SUPABASE_URL
#      - Copy the Publishable Key (sb_publishable_...) → paste as VITE_SUPABASE_ANON_KEY
#    Option B (legacy): Go to Settings > API Keys > Legacy API Keys
#      - Copy the Project URL → paste as VITE_SUPABASE_URL
#      - Copy the anon/public key → paste as VITE_SUPABASE_ANON_KEY
#
#
# STEP 2: Create Database Table
# ---------------------------------
# Go to SQL Editor in Supabase and run this SQL:
#
#    create table wingman_backups (
#      id text primary key,
#      user_id text,
#      data jsonb,
#      updated_at timestamp with time zone
#    );
#
#    alter table wingman_backups enable row level security;
#
#    create policy "Users can manage their own data" on wingman_backups
#      for all using (auth.uid()::text = user_id);
#
#
# STEP 3: Enable Email Authentication
# ---------------------------------
# Go to Authentication > Providers in Supabase
# - Email provider is enabled by default
# - Users can sign up with email/password immediately
#
#
# STEP 4: (Optional) Setup Google OAuth
# ---------------------------------
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Go to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "OAuth client ID"
# 5. Configure OAuth consent screen if prompted
# 6. Create OAuth client ID (Web application)
#    - Authorized redirect URI: copy from Supabase > Authentication > Providers > Google
# 7. Paste Client ID and Secret into Supabase > Authentication > Providers > Google
#
#
# STEP 5: (Optional) Setup GitHub OAuth
# ---------------------------------
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
#    - Authorization callback URL: copy from Supabase > Authentication > Providers > GitHub
# 3. Paste Client ID and Secret into Supabase > Authentication > Providers > GitHub
#
#
# STEP 6: Restart Dev Server
# ---------------------------------
# 1. Save this file
# 2. Restart: npm run dev
# 3. The auth screen will appear automatically
#
# ============================================
# Notes:
# ============================================
# - Both publishable keys (sb_publishable_...) and legacy anon keys (eyJhbG...) work
# - Email/password works immediately after Step 2
# - OAuth (Google/GitHub) is completely optional
# - Users can always choose "Continue without an account" for local-only mode
#
